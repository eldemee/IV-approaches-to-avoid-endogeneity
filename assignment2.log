. *Here I set seed to 1000 so that the task can be replicated
. 
. *Monte Carlo again
. foreach i of numlist 50 1000 {
  2.         tempfile ivmc`i'
  3.         local j = 1
  4.         while `j' <= 1000 {
  5.                 quietly{
  6.                         preserve
  7.                         sample `i', count
  8.                         noisily di "." _continue
  9.                         
.                         *Regenerating errors
.                         replace e = invnorm(uniform())
 10.                         replace y = 1 + x1 + x2 + e
 11.                         replace x2_e1 = x2 + 0.5*invnorm(uniform())
 12.                         replace x2_e2 = x2 + invnorm(uniform())
 13.                         
.                         ivregress 2sls y x1 (x2_e1 = x2_e2)
 14.                         matrix b1 = e(b)
 15.                         ivregress 2sls y x1 (x2_e2 = x2_e1)
 16.                         matrix b2 = e(b)
 17.                         reg y x1 x2_e1 x2_e2
 18.                         matrix both = e(b)
 19.                         
.                         svmat b1, name(ols_smaller`i')
 20.                         svmat b2, name(ols_larger`i')
 21.                         svmat both, name(ols_both`i')
 22.                         collapse (mean) ols_smaller* ols_larger* ols_bo
> th*
 23.                         
.                         if `j' > 1 {
 24.                                 append using `ivmc`i''
 25.                         }
 26.                         save `ivmc`i'', replace
 27.                         
.                         restore
 28.                         
.                         local j = `j' + 1
 29.                  }
 30.         }
 31. }
